# ─────────────────────────────────────────────────────────────
# Hermes 工作区 .gitignore
# 原则：源码/文档/规则/研究笔记 入库；运行时数据/密钥/缓存/大二进制 排除
# ─────────────────────────────────────────────────────────────

# ── Python 缓存与编译产物 ──
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.ipynb_checkpoints/

# ── 虚拟环境（如有）──
venv/
.venv/
env/
ENV/

# ── Node（polymarket-dashboard 等如有前端构建）──
node_modules/
dist/
build/
*.tsbuildinfo

# ── 数据库实例与本地数据（PostgreSQL 数据目录，绝不入库）──
StockChoose/pgdata/
StockChoose/tmp/
*.db
*.sqlite
*.sqlite3
*.db-journal
*.db-wal
*.db-shm

# ── 备份文件（用户偏好：靠 git 回退，不留本地备份）──
*.bak
*.bak.*
*.backup
*.bak_*
*~
# ie.py 引擎自动生成的备份目录（git 已是回退机制，无需入库）
innovation-engine/engine/.backups/

# ── 日志 ──
*.log
logs/
*/logs/

# ── 运行时配置 / 密钥目录（含 token、page_id 等环境配置）──
.openclaw/
.env
.env.*
*.pem
*.key
secrets.json
credentials.json

# ── 大体积数据快照 / 抓取缓存（可再生，不入库）──
polymarket-dashboard/data/snapshot_latest.json
polymarket-dashboard/data/snapshots/
us-tech-scout/data/latest_scan.json
*/data/snapshot_*.json
*/data/snapshots/
*.cache
.cache/

# ── 系统文件 ──
.DS_Store
Thumbs.db

# ── 心跳 / 进程状态（运行时产物）──
*.pid
heartbeat.txt
workspace-state.json

# Quant-Futu 是独立 git 仓库(独立remote),不纳入workspace跟踪,避免gitlink与子仓库打架
Quant-Futu/

# limit-order-book 是外部第三方独立 git 仓库(remote=github.com/mansoor-mamnoon,HFT订单簿模拟器,含大量二进制/parquet/TAQ数据),非本组合治理项目,同 Quant-Futu 处理:不纳入workspace跟踪,避免误 git add 把外部仓库嵌成 gitlink 污染实盘仓库
limit-order-book/

# 运行时状态/缓存文件(由各系统自动读写,不纳入git跟踪,避免每次跑都冒未提交噪音)
# 注:ignore只停止跟踪,工作区文件保留,程序照常读写,累积状态不丢
hormones/state.json
paper-trading/akeso_trials/trial_state.json
polymarket-dashboard/data/changes_1h.json
ai-teacher/comment_review_state.json
ai-teacher/pending_comments.json
ai-teacher/scan_comments.log

# 运行时锁文件
*.app.lock
.app.lock

# ai-research 论文全文PDF(可从arXiv重下,不入库)
ai-research/papers_pdf/
